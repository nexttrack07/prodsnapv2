{
  "name": "tanstack-start-example-convex-trellaux",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec convex dev --once && concurrently -r pnpm:dev:web pnpm:dev:db",
    "dev:web": "vite dev",
    "dev:db": "convex dev --run board:seed",
